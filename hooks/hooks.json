{
  "description": "gemini-visual-design hooks — API key validation on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-api-key.sh"
          }
        ]
      }
    ]
  }
}
